  <data name="TransparentWebViewScript" xml:space="preserve">
    <value>(()=&gt;{window.__WINUI_ON_WEB_UWP_APP__=true;const root=document.documentElement;root.classList.add('winui-webview-host');const id='winui-on-web-transparent-background';let style=document.getElementById(id);if(!style){style=document.createElement('style');style.id=id;(document.head||root).appendChild(style);}style.textContent=`html.winui-webview-host{--app-bg:transparent!important;background:transparent!important;background-color:transparent!important;}html.winui-webview-host:not(.theme-dark){--host-layer-default:rgba(255,255,255,.50);--host-nav-pane-bg:rgba(243,243,243,.72);--host-flyout-bg:rgba(252,252,252,.78);}html.winui-webview-host.theme-dark{--host-layer-default:rgba(58,58,58,.25);--host-nav-pane-bg:rgba(32,32,32,.72);--host-flyout-bg:rgba(44,44,44,.78);}@media (prefers-color-scheme:dark){html.winui-webview-host:not(.theme-light){--host-layer-default:rgba(58,58,58,.25);--host-nav-pane-bg:rgba(32,32,32,.72);--host-flyout-bg:rgba(44,44,44,.78);}}html.winui-webview-host body,html.winui-webview-host #app,html.winui-webview-host .win-nav-shell{background:transparent!important;background-color:transparent!important;}html.winui-webview-host .win-nav-top-bar{background-color:transparent!important;}html.winui-webview-host .win-nav-content{background:var(--host-layer-default)!important;background-color:var(--host-layer-default)!important;}html.winui-webview-host .win-nav-shell.is-overlay-left .win-nav-left-panel:not(.is-compact){background:var(--host-nav-pane-bg)!important;background-color:var(--host-nav-pane-bg)!important;backdrop-filter:blur(28px) saturate(1.35)!important;-webkit-backdrop-filter:blur(28px) saturate(1.35)!important;}html.winui-webview-host .win-menu-flyout{background:var(--host-flyout-bg)!important;background-color:var(--host-flyout-bg)!important;backdrop-filter:var(--flyout-backdrop)!important;-webkit-backdrop-filter:var(--flyout-backdrop)!important;}`;})()</value>
  </data>
