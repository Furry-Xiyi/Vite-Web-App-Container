  <data name="WebMaterialIntegrationScriptBox.Text" xml:space="preserve">
    <value>const setWinUIHostMaterial = (value) =&gt; {
  if (!window.__WINUI_ON_WEB_UWP_APP__ || !window.chrome?.webview) {
    return;
  }

  window.chrome.webview.postMessage({
    source: 'WinUIonWeb',
    type: 'appSettingChanged',
    key: 'material',
    value
  });
};

setWinUIHostMaterial('mica');
setWinUIHostMaterial('acrylic');</value>
