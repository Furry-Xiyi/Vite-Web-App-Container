  <data name="WebThemeIntegrationScriptBox.Text" xml:space="preserve">
    <value>const setWinUIHostTheme = (value) =&gt; {
  if (!window.__WINUI_ON_WEB_UWP_APP__ || !window.chrome?.webview) {
    return;
  }

  window.chrome.webview.postMessage({
    source: 'WinUIonWeb',
    type: 'appSettingChanged',
    key: 'theme',
    value
  });
};

setWinUIHostTheme('system');
setWinUIHostTheme('light');
setWinUIHostTheme('dark');</value>
