  <data name="WebShellBridgeCard.Header" xml:space="preserve"><value>Calling the host</value></data>
  <data name="WebShellBridgeCard.Description" xml:space="preserve"><value>The host injects a Promise API: it returns a result, null when cancelled, and throws Error on failure</value></data>
  <data name="WebShellBridgeScriptBox.Text" xml:space="preserve"><value>const result = await window.winuiHost.invoke(
  'actionName',
  { key: 'value' }
);</value></data>
