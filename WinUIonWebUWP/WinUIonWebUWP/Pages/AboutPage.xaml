<Page
    x:Class="WinUIonWebUWP.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Height="48"
              Padding="12,0"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Width="36"
                    Height="36"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackButton_Click">
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          FontSize="14"
                          Glyph="&#xE72B;"/>
            </Button>

            <muxc:BreadcrumbBar x:Name="Breadcrumb"
                                Grid.Column="1"
                                VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Padding="20,20,20,20">
            <StackPanel Spacing="32">
                <StackPanel Spacing="3">
                    <TextBlock x:Uid="BehaviorGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsCard x:Uid="TransparentCssCard"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           Padding="16,8">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE771;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ItemsControl x:Name="TransparentCssRulesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44"
                                          Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Selector}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Css}"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Margin="8,0,0,0"
                                                Tag="{Binding}"
                                                Click="EditCssRuleButton_Click">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      FontSize="14"
                                                      Glyph="&#xE70F;"/>
                                        </Button>

                                        <Button Grid.Column="2"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Margin="4,0,0,0"
                                                Tag="{Binding}"
                                                Click="DeleteCssRuleButton_Click">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      FontSize="14"
                                                      Glyph="&#xE74D;"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </controls:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="SoundGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsCard x:Uid="Settings_SoundCard"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           MinHeight="70"
                                           Padding="16,0">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE767;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="SoundToggle"
                                      HorizontalAlignment="Right"
                                      Toggled="SoundToggle_Toggled"/>
                    </controls:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="AboutGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <muxc:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   MinHeight="70">
                        <muxc:Expander.Header>
                            <Grid HorizontalAlignment="Stretch"
                                  Margin="1,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImgAppIcon"
                                       Grid.Column="0"
                                       Width="20"
                                       Height="20"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Margin="21,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtAppName"
                                               FontSize="14.4"/>
                                    <TextBlock x:Name="TxtCopyright"
                                               FontSize="12"
                                               Opacity="0.8"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtVersion"
                                           Grid.Column="2"
                                           FontSize="14.4"
                                           Opacity="0.7"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </muxc:Expander.Header>
                        <StackPanel>
                            <HyperlinkButton Click="OpenExternalLink"
                                             Tag="https://qm.qq.com/q/UPnTGW164m"
                                             HorizontalAlignment="Left">
                                <TextBlock x:Uid="QQGroup"
                                           VerticalAlignment="Center"/>
                            </HyperlinkButton>
                            <HyperlinkButton Click="OpenExternalLink"
                                             Tag="https://discord.gg/4NScc8sEzw"
                                             HorizontalAlignment="Left">
                                <TextBlock x:Uid="DiscordGroup"
                                           VerticalAlignment="Center"/>
                            </HyperlinkButton>
                        </StackPanel>
                    </muxc:Expander>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,20,0,20">
                        <FontIcon Glyph="&#xED15;"
                                  FontSize="20"
                                  VerticalAlignment="Center"/>
                        <HyperlinkButton Click="OpenExternalLink"
                                         Tag="https://forms.office.com/r/jzsFaQKCpr"
                                         Padding="0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center">
                            <TextBlock x:Uid="Feedback"/>
                        </HyperlinkButton>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
