<Page
    x:Class="WinUIonWebUWP.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:pages="using:WinUIonWebUWP.Pages"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Grid Background="Transparent">
        <ScrollViewer Padding="20,0,20,20"
                      Background="Transparent">
            <StackPanel Spacing="32">
                <StackPanel Spacing="3">
                    <TextBlock x:Uid="BehaviorGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsExpander x:Name="TransparentCssExpander"
                                               x:Uid="TransparentCssCard"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE771;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <ToggleSwitch x:Name="PerSiteCssToggle"
                                          x:Uid="PerSiteCssToggle"
                                          VerticalAlignment="Center"
                                          Toggled="PerSiteCssToggle_Toggled"/>
                            <Button x:Name="AddCssRuleButton"
                                    x:Uid="AddCssRuleButton"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Click="AddCssRuleButton_Click">
                                <FontIcon FontSize="14"
                                          Glyph="&#xE710;"/>
                            </Button>
                        </StackPanel>
                        <controls:SettingsExpander.ItemsHeader>
                            <ItemsControl x:Name="RulesItemsControl"
                                          ItemsSource="{x:Bind Rules, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="pages:TransparentCssRuleViewModel">
                                        <controls:SettingsCard Header="{x:Bind Header, Mode=OneWay}"
                                                               Description="{x:Bind Description, Mode=OneWay}"
                                                               HorizontalAlignment="Stretch"
                                                               HorizontalContentAlignment="Stretch">
                                            <Grid RowSpacing="8"
                                                  MinWidth="320"
                                                  MaxWidth="720">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBox x:Name="CssHostBox"
                                                         x:Uid="CssHostBox"
                                                         Text="{x:Bind Host, Mode=OneWay}"
                                                         Visibility="{x:Bind HostVisibility, Mode=OneWay}"
                                                         TextChanged="CssRuleTextBox_TextChanged"/>

                                                <TextBox x:Name="CssSelectorBox"
                                                         Grid.Row="1"
                                                         x:Uid="CssSelectorBox"
                                                         Text="{x:Bind Selector, Mode=OneWay}"
                                                         TextChanged="CssRuleTextBox_TextChanged"/>

                                                <TextBox x:Name="CssContentBox"
                                                         Grid.Row="2"
                                                         x:Uid="CssContentBox"
                                                         Text="{x:Bind Css, Mode=OneWay}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="88"
                                                         TextChanged="CssRuleTextBox_TextChanged"/>

                                                <StackPanel Grid.Row="3"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Spacing="8">
                                                    <Button x:Name="DeleteCssRuleButton"
                                                            x:Uid="DeleteCssRuleButton"
                                                            Width="32"
                                                            Height="32"
                                                            Padding="0"
                                                            Click="DeleteCssRuleButton_Click">
                                                        <FontIcon FontSize="14"
                                                                  Glyph="&#xE74D;"/>
                                                    </Button>
                                                    <Button x:Name="SaveCssRuleButton"
                                                            x:Uid="SaveCssRuleButton"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Visibility="{x:Bind SaveVisibility, Mode=OneWay}"
                                                            Click="SaveCssRuleButton_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </controls:SettingsCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </controls:SettingsExpander.ItemsHeader>
                    </controls:SettingsExpander>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="ContainersGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsCard x:Uid="ContainersManagementCard"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           MinHeight="70"
                                           Padding="16,0"
                                           IsClickEnabled="True"
                                           Click="ContainersManagementCard_Click">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8A7;"/>
                        </controls:SettingsCard.HeaderIcon>
                    </controls:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="SoundGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsCard x:Uid="Settings_SoundCard"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           MinHeight="70"
                                           Padding="16,0">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE767;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="SoundToggle"
                                      HorizontalAlignment="Right"
                                      Toggled="SoundToggle_Toggled"/>
                    </controls:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="DeveloperGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <controls:SettingsExpander x:Name="F12DevToolsExpander"
                                               x:Uid="F12DevToolsCard"
                                               IsExpanded="False"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xEC7A;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <ToggleSwitch x:Name="F12DevToolsToggle"
                                      VerticalAlignment="Center"
                                      Toggled="F12DevToolsToggle_Toggled"/>
                        <controls:SettingsExpander.ItemsHeader>
                            <ItemsControl x:Name="DevToolsSitesItemsControl"
                                          ItemsSource="{x:Bind DevToolsSites, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="pages:DevToolsSiteViewModel">
                                        <controls:SettingsCard Header="{x:Bind DisplayName, Mode=OneWay}"
                                                               Description="{x:Bind HomeUrl, Mode=OneWay}"
                                                               HorizontalAlignment="Stretch"
                                                               HorizontalContentAlignment="Stretch"
                                                               MinHeight="70"
                                                               Padding="16,0">
                                            <controls:SettingsCard.HeaderIcon>
                                                <BitmapIcon UriSource="{x:Bind IconUri, Mode=OneWay}"
                                                            ShowAsMonochrome="False"/>
                                            </controls:SettingsCard.HeaderIcon>
                                            <ToggleSwitch IsOn="{x:Bind IsDevToolsEnabled, Mode=OneWay}"
                                                          IsEnabled="{x:Bind IsMasterEnabled, Mode=OneWay}"
                                                          Tag="{x:Bind Id, Mode=OneWay}"
                                                          VerticalAlignment="Center"
                                                          Toggled="DevToolsSiteToggle_Toggled"/>
                                        </controls:SettingsCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </controls:SettingsExpander.ItemsHeader>
                    </controls:SettingsExpander>

                    <controls:SettingsExpander x:Name="ViteDevServerExpander"
                                               x:Uid="ViteDevServerCard"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE756;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button x:Name="ViteStartButton"
                                    x:Uid="ViteStartButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="ViteStartButton_Click"/>
                            <Button x:Name="ViteStopButton"
                                    x:Uid="ViteStopButton"
                                    Click="ViteStopButton_Click"/>
                            <Button x:Name="ViteRetryButton"
                                    x:Uid="ViteRetryButton"
                                    Click="ViteRetryButton_Click"/>
                        </StackPanel>
                        <controls:SettingsExpander.ItemsHeader>
                            <StackPanel Spacing="0">
                                <controls:SettingsCard x:Uid="ViteServerConfigCard"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Stretch">
                                    <Grid RowSpacing="8"
                                          ColumnSpacing="8"
                                          MinWidth="320"
                                          MaxWidth="760">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="ViteHostBox"
                                                 x:Uid="ViteHostBox"
                                                 TextChanged="ViteDevServerTextBox_TextChanged"/>
                                        <muxc:NumberBox x:Name="VitePortNumberBox"
                                                        Grid.Column="1"
                                                        x:Uid="VitePortNumberBox"
                                                        Minimum="1"
                                                        Maximum="65535"
                                                        SmallChange="1"
                                                        LargeChange="100"
                                                        SpinButtonPlacementMode="Compact"
                                                        ValueChanged="VitePortNumberBox_ValueChanged"/>

                                        <Grid Grid.Row="1"
                                              Grid.ColumnSpan="2"
                                              ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ViteUsePathCheckBox"
                                                      x:Uid="ViteUsePathCheckBox"
                                                      VerticalAlignment="Bottom"
                                                      Checked="ViteUsePathCheckBox_Changed"
                                                      Unchecked="ViteUsePathCheckBox_Changed"/>
                                            <TextBox x:Name="VitePathBox"
                                                     Grid.Column="1"
                                                     x:Uid="VitePathBox"
                                                     TextChanged="ViteDevServerTextBox_TextChanged"/>
                                        </Grid>

                                        <TextBox x:Name="ViteCommandBox"
                                                 Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 x:Uid="ViteCommandBox"
                                                 TextChanged="ViteDevServerTextBox_TextChanged"/>

                                        <Grid Grid.Row="3"
                                              Grid.ColumnSpan="2"
                                              ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ViteWorkingDirectoryBox"
                                                     x:Uid="ViteWorkingDirectoryBox"
                                                     TextChanged="ViteDevServerTextBox_TextChanged"/>
                                            <Button x:Name="ViteBrowseFolderButton"
                                                    Grid.Column="1"
                                                    x:Uid="ViteBrowseFolderButton"
                                                    MinHeight="32"
                                                    VerticalAlignment="Bottom"
                                                    Click="ViteBrowseFolderButton_Click"/>
                                            <Button x:Name="ViteOpenFolderButton"
                                                    Grid.Column="2"
                                                    x:Uid="ViteOpenFolderButton"
                                                    MinHeight="32"
                                                    VerticalAlignment="Bottom"
                                                    Click="ViteOpenFolderButton_Click"/>
                                        </Grid>

                                        <StackPanel Grid.Row="4"
                                                    Grid.ColumnSpan="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Spacing="8">
                                            <Button x:Name="ViteUseDefaultButton"
                                                    x:Uid="ViteUseDefaultButton"
                                                    Click="ViteUseDefaultButton_Click"/>
                                            <Button x:Name="ViteOpenUrlButton"
                                                    x:Uid="ViteOpenUrlButton"
                                                    Click="ViteOpenUrlButton_Click"/>
                                            <Button x:Name="ViteReloadCurrentButton"
                                                    x:Uid="ViteReloadCurrentButton"
                                                    Click="ViteReloadCurrentButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </controls:SettingsCard>

                                <controls:SettingsCard x:Uid="ViteServerStatusCard"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Stretch">
                                    <StackPanel Spacing="6"
                                                MinWidth="320"
                                                MaxWidth="760">
                                        <TextBlock x:Name="ViteUrlText"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ViteStatusText"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ViteHmrHintText"
                                                   FontSize="12"
                                                   Opacity="0.72"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed"/>
                                        <TextBox x:Name="ViteLogBox"
                                                 MinHeight="104"
                                                 MaxHeight="220"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 FontSize="12"/>
                                    </StackPanel>
                                </controls:SettingsCard>
                            </StackPanel>
                        </controls:SettingsExpander.ItemsHeader>
                    </controls:SettingsExpander>

                    <controls:SettingsExpander x:Uid="WebIntegrationCard"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE943;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.ItemsHeader>
                            <StackPanel Spacing="0">
                                <controls:SettingsCard x:Uid="WebMaterialIntegrationCard"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Stretch">
                                    <TextBox x:Uid="WebMaterialIntegrationScriptBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             MinHeight="128"
                                             HorizontalAlignment="Stretch"/>
                                </controls:SettingsCard>
                            </StackPanel>
                        </controls:SettingsExpander.ItemsHeader>
                    </controls:SettingsExpander>

                    <controls:SettingsCard x:Uid="DownloadFolderCard"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           MinHeight="70"
                                           Padding="16,0">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE838;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <Grid ColumnSpacing="8"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              MaxWidth="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DownloadFolderPathText"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button x:Name="BrowseDownloadFolderButton"
                                    Grid.Column="1"
                                    x:Uid="BrowseDownloadFolderButton"
                                    Click="BrowseDownloadFolderButton_Click"/>
                        </Grid>
                    </controls:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock x:Uid="AboutGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <muxc:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   MinHeight="70">
                        <muxc:Expander.Header>
                            <Grid HorizontalAlignment="Stretch"
                                  Margin="1,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImgAppIcon"
                                       Grid.Column="0"
                                       Width="20"
                                       Height="20"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Margin="21,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtAppName"
                                               FontSize="14.4"/>
                                    <TextBlock x:Name="TxtCopyright"
                                               FontSize="12"
                                               Opacity="0.8"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtVersion"
                                           Grid.Column="2"
                                           FontSize="14.4"
                                           Opacity="0.7"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </muxc:Expander.Header>
                        <StackPanel>
                            <HyperlinkButton Click="OpenExternalLink"
                                             Tag="https://qm.qq.com/q/UPnTGW164m"
                                             HorizontalAlignment="Left">
                                <TextBlock x:Uid="QQGroup"
                                           VerticalAlignment="Center"/>
                            </HyperlinkButton>
                            <HyperlinkButton Click="OpenExternalLink"
                                             Tag="https://discord.gg/4NScc8sEzw"
                                             HorizontalAlignment="Left">
                                <TextBlock x:Uid="DiscordGroup"
                                           VerticalAlignment="Center"/>
                            </HyperlinkButton>
                        </StackPanel>
                    </muxc:Expander>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,20,0,20">
                        <FontIcon Glyph="&#xED15;"
                                  FontSize="20"
                                  VerticalAlignment="Center"/>
                        <HyperlinkButton Click="OpenExternalLink"
                                         Tag="https://forms.office.com/r/jzsFaQKCpr"
                                         Padding="0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center">
                            <TextBlock x:Uid="Feedback"/>
                        </HyperlinkButton>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
