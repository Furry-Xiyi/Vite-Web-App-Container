<Page
    x:Class="WinUIonWebUWP.Pages.ContainerManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:pages="using:WinUIonWebUWP.Pages">

    <Grid Background="Transparent">
        <ScrollViewer Padding="20,0,20,20"
                      Background="Transparent">
            <StackPanel Spacing="18">
                <StackPanel Spacing="3">
                    <TextBlock x:Uid="ContainerManagementGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <ItemsControl x:Name="ContainersItemsControl"
                                  ItemsSource="{x:Bind Containers, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="pages:ContainerItemViewModel">
                                <controls:SettingsExpander Header="{x:Bind DisplayName, Mode=OneWay}"
                                                           Description="{x:Bind HomeUrl, Mode=OneWay}"
                                                           HorizontalAlignment="Stretch"
                                                           HorizontalContentAlignment="Stretch">
                                    <controls:SettingsExpander.HeaderIcon>
                                        <BitmapIcon UriSource="{x:Bind IconUri, Mode=OneWay}"
                                                    ShowAsMonochrome="False"/>
                                    </controls:SettingsExpander.HeaderIcon>
                                    <Button x:Uid="ContainerOpenButton"
                                            Visibility="{x:Bind OpenVisibility, Mode=OneWay}"
                                            Tag="{x:Bind Id, Mode=OneWay}"
                                            Click="OpenContainerButton_Click"/>
                                    <controls:SettingsExpander.ItemsHeader>
                                        <Grid RowSpacing="8"
                                              MinWidth="320"
                                              MaxWidth="760"
                                              Padding="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBox x:Name="ContainerNameBox"
                                                     x:Uid="ContainerNameBox"
                                                     Text="{x:Bind DisplayName, Mode=OneWay}"
                                                     TextChanged="ContainerTextBox_TextChanged"/>
                                            <TextBox x:Name="ContainerUrlBox"
                                                     Grid.Row="1"
                                                     x:Uid="ContainerUrlBox"
                                                     Text="{x:Bind HomeUrl, Mode=OneWay}"
                                                     TextChanged="ContainerTextBox_TextChanged"/>

                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Spacing="8">
                                                <Button x:Uid="ContainerRefreshIconButton"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Tag="{x:Bind Id, Mode=OneWay}"
                                                        Click="RefreshContainerIconButton_Click">
                                                    <FontIcon FontSize="14"
                                                              Glyph="&#xE72C;"/>
                                                </Button>
                                                <Button x:Uid="ContainerClearDataButton"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Tag="{x:Bind Id, Mode=OneWay}"
                                                        Click="ClearContainerDataButton_Click">
                                                    <FontIcon FontSize="14"
                                                              Glyph="&#xEA99;"/>
                                                </Button>
                                                <Button x:Uid="ContainerUnpinButton"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Tag="{x:Bind Id, Mode=OneWay}"
                                                        Click="UnpinContainerButton_Click">
                                                    <FontIcon FontSize="14"
                                                              Glyph="&#xE77A;"/>
                                                </Button>
                                                <Button x:Uid="ContainerDeleteButton"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        IsEnabled="{x:Bind CanDelete, Mode=OneWay}"
                                                        Tag="{x:Bind Id, Mode=OneWay}"
                                                        Click="DeleteContainerButton_Click">
                                                    <FontIcon FontSize="14"
                                                              Glyph="&#xE74D;"/>
                                                </Button>
                                                <Button x:Uid="ContainerSaveButton"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Tag="{x:Bind Id, Mode=OneWay}"
                                                        Click="SaveContainerButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </controls:SettingsExpander.ItemsHeader>
                                </controls:SettingsExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
