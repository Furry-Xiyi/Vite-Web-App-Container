<Page
    x:Class="WinUIonWebUWP.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20"
          Background="Transparent">
        <StackPanel Spacing="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="420">
            <FontIcon Glyph="&#xE946;"
                      FontSize="28"
                      HorizontalAlignment="Center"/>
            <TextBlock x:Uid="SettingsPageMigratedTitle"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
            <TextBlock x:Uid="SettingsPageMigratedDescription"
                       FontSize="13"
                       Opacity="0.72"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
