<Page
    x:Class="WinUIonWebUWP.Pages.ContainerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Background="Transparent">
        <muxc:WebView2 x:Name="RootWebView"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

        <Grid x:Name="LoadingOverlay"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Opacity="0.92"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <muxc:ProgressRing IsActive="True"
                              Width="36"
                              Height="36"/>
                <TextBlock x:Uid="WebViewLoadingText"
                           HorizontalAlignment="Center"
                           Opacity="0.72"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="NavigationErrorOverlay"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="Collapsed">
            <StackPanel Width="360"
                        MaxWidth="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <FontIcon Glyph="&#xE783;"
                          FontSize="36"
                          HorizontalAlignment="Center"
                          Opacity="0.86"/>
                <TextBlock x:Uid="NavigationErrorTitle"
                           HorizontalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="NavigationErrorMessage"
                           TextWrapping="WrapWholeWords"
                           TextAlignment="Center"
                           Opacity="0.78"/>
                <TextBlock x:Name="NavigationErrorUrlText"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center"
                           FontSize="12"
                           Opacity="0.62"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Margin="0,4,0,0">
                    <Button x:Name="RetryNavigationButton"
                            x:Uid="RetryNavigationButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="RetryNavigationButton_Click"/>
                    <Button x:Name="CopyNavigationUrlButton"
                            x:Uid="CopyNavigationUrlButton"
                            Style="{ThemeResource ButtonRevealStyle}"
                            Click="CopyNavigationUrlButton_Click"/>
                    <Button x:Name="OpenNavigationExternalButton"
                            x:Uid="OpenNavigationExternalButton"
                            Style="{ThemeResource ButtonRevealStyle}"
                            Click="OpenNavigationExternalButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
