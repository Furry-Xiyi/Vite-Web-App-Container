<Page
    x:Class="WinUIonWebUWP.Pages.SitePermissionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:pages="using:WinUIonWebUWP.Pages">

    <Grid Background="Transparent">
        <ScrollViewer Padding="20,0,20,20"
                      Background="Transparent">
            <StackPanel Spacing="18">
                <StackPanel Spacing="3">
                    <TextBlock x:Uid="SitePermissionsGroup"
                               FontSize="14"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="OriginText"
                               FontSize="12"
                               Opacity="0.72"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <ItemsControl x:Name="PermissionItemsControl"
                                  ItemsSource="{x:Bind Permissions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="pages:SitePermissionViewModel">
                                <controls:SettingsCard Header="{x:Bind DisplayName, Mode=OneWay}"
                                                       Description="{x:Bind Description, Mode=OneWay}"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Stretch">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="{x:Bind Glyph, Mode=OneWay}"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <ComboBox Width="140"
                                              SelectedIndex="{x:Bind SelectedIndex, Mode=OneWay}"
                                              Tag="{x:Bind PermissionKind, Mode=OneWay}"
                                              SelectionChanged="PermissionStateComboBox_SelectionChanged">
                                        <ComboBoxItem x:Uid="PermissionStateAsk"/>
                                        <ComboBoxItem x:Uid="PermissionStateAllow"/>
                                        <ComboBoxItem x:Uid="PermissionStateDeny"/>
                                    </ComboBox>
                                </controls:SettingsCard>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
