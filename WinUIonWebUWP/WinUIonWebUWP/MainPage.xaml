<Page
    x:Class="WinUIonWebUWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals">

    <Grid>
        <Grid x:Name="TitleBarArea"
              Height="32"
              Background="Transparent"
              VerticalAlignment="Top"
              Canvas.ZIndex="1">

            <Grid x:Name="TitleBarDragArea"
                  Margin="0,0,48,0"
                  Background="Transparent"/>

            <Button x:Name="SettingsBackButton"
                    x:Uid="SettingsBackButton"
                    Width="32"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Visibility="Collapsed"
                    PointerEntered="SettingsBackButton_PointerEntered"
                    PointerExited="SettingsBackButton_PointerExited"
                    PointerPressed="SettingsBackButton_PointerPressed"
                    PointerReleased="SettingsBackButton_PointerReleased"
                    Click="SettingsBackButton_Click">
                <muxc:AnimatedIcon x:Name="SettingsBackAnimatedIcon" Width="14" Height="14">
                    <muxc:AnimatedIcon.Source>
                        <animatedvisuals:AnimatedBackVisualSource/>
                    </muxc:AnimatedIcon.Source>
                    <muxc:AnimatedIcon.FallbackIconSource>
                        <muxc:FontIconSource Glyph="&#xE72B;" FontSize="14"/>
                    </muxc:AnimatedIcon.FallbackIconSource>
                </muxc:AnimatedIcon>
            </Button>

            <StackPanel x:Name="TitleBarIdentityArea"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0"
                        IsHitTestVisible="False">

                <Image x:Name="ImgAppIcon"
                       Width="16"
                       Height="16"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                <TextBlock x:Name="TitleBarAppName"
                           VerticalAlignment="Center"
                           FontSize="14"/>
            </StackPanel>

            <Button x:Name="MoreButton"
                    x:Uid="MoreButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0">
                <FontIcon FontSize="14"
                          Glyph="&#xE712;"/>
                <Button.Flyout>
                    <Flyout x:Name="MoreFlyout"
                            Opening="MoreFlyout_Opening"
                            Opened="MoreFlyout_Opened">
                        <StackPanel Width="320"
                                    Spacing="12">
                            <AutoSuggestBox x:Name="UrlAutoSuggestBox"
                                            x:Uid="UrlAutoSuggestBox"
                                            TabIndex="1"
                                            GotFocus="UrlAutoSuggestBox_GotFocus"
                                            Tapped="UrlAutoSuggestBox_Tapped"
                                            TextChanged="UrlAutoSuggestBox_TextChanged"
                                            SuggestionChosen="UrlAutoSuggestBox_SuggestionChosen"
                                            QuerySubmitted="UrlAutoSuggestBox_QuerySubmitted">
                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="40"
                                              MinWidth="280">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <AppBarButton x:Uid="DeleteUrlHistoryButton"
                                                          Grid.Column="1"
                                                          Width="32"
                                                          Height="32"
                                                          MinWidth="32"
                                                          MinHeight="32"
                                                          Padding="0"
                                                          Label=""
                                                          Background="Transparent"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                          Tag="{Binding}"
                                                          Click="DeleteUrlHistoryButton_Click">
                                                <AppBarButton.Template>
                                                    <ControlTemplate TargetType="AppBarButton">
                                                        <Grid Width="32"
                                                              Height="32"
                                                              Background="Transparent">
                                                            <VisualStateManager.VisualStateGroups>
                                                                <VisualStateGroup x:Name="CommonStates">
                                                                    <VisualState x:Name="Normal"/>
                                                                    <VisualState x:Name="PointerOver">
                                                                        <Storyboard>
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBackground"
                                                                                                           Storyboard.TargetProperty="Background">
                                                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                                                        Value="{ThemeResource SystemControlHighlightListLowBrush}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Pressed">
                                                                        <Storyboard>
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBackground"
                                                                                                           Storyboard.TargetProperty="Background">
                                                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                                                        Value="{ThemeResource SystemControlHighlightListMediumBrush}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Disabled"/>
                                                                </VisualStateGroup>
                                                            </VisualStateManager.VisualStateGroups>
                                                            <Border x:Name="ButtonBackground"
                                                                    CornerRadius="4"
                                                                    Background="Transparent"/>
                                                            <ContentPresenter Content="{TemplateBinding Icon}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </AppBarButton.Template>
                                                <AppBarButton.Icon>
                                                    <FontIcon FontSize="10"
                                                              Glyph="&#xE711;"/>
                                                </AppBarButton.Icon>
                                            </AppBarButton>
                                        </Grid>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>

                            <TextBlock x:Name="UrlErrorText"
                                       x:Uid="UrlErrorText"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8">
                                <Button x:Name="RestoreUrlButton"
                                        x:Uid="RestoreUrlButton"
                                        Click="RestoreUrlButton_Click"/>
                                <Button x:Name="CancelUrlButton"
                                        x:Uid="CancelUrlButton"
                                        Click="CancelUrlButton_Click"/>
                                <Button x:Name="SaveUrlButton"
                                        x:Uid="SaveUrlButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="SaveUrlButton_Click"/>
                            </StackPanel>

                            <StackPanel Margin="-15,0,-15,-15"
                                        Padding="2,2,2,2"
                                        Spacing="2">
                                <Border Height="1"
                                        Margin="-12,0"
                                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                        Opacity="0.6"/>

                                <Button x:Name="SettingsEntryButton"
                                        x:Uid="SettingsEntryButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="SettingsEntryButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE713;"
                                                  FontSize="16"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Uid="SettingsEntryText"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Frame x:Name="ContentFrame"
               Margin="0,32,0,0"/>

        <Grid x:Name="SettingsHost"
              Visibility="Collapsed"
              Background="Transparent"
              Margin="0,32,0,0"
              Canvas.ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Padding="20,16,20,12"
                        Spacing="8">
                <StackPanel x:Name="BreadcrumbPanel"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                <muxc:BreadcrumbBar x:Name="BreadcrumbNav"
                                    ItemsSource="{x:Bind BreadcrumbItems, Mode=OneWay}">
                    <muxc:BreadcrumbBar.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="28"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </DataTemplate>
                    </muxc:BreadcrumbBar.ItemTemplate>
                </muxc:BreadcrumbBar>
                </StackPanel>
            </StackPanel>

            <Frame x:Name="SettingsFrame"
                   Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>
