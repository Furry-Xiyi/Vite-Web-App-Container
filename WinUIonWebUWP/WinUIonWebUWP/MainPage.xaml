<Page
    x:Class="WinUIonWebUWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUIonWebUWP"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <Grid x:Name="TitleBarArea"
              Height="32"
              Background="Transparent"
              VerticalAlignment="Top"
              Canvas.ZIndex="1">

            <Grid x:Name="TitleBarDragArea"
                  Margin="0,0,48,0"
                  Background="Transparent"/>

            <StackPanel x:Name="TitleBarIdentityArea"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0"
                        IsHitTestVisible="False">

                <Image x:Name="ImgAppIcon"
                       Width="16"
                       Height="16"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                <TextBlock x:Name="TitleBarAppName"
                           VerticalAlignment="Center"
                           FontSize="12"/>
            </StackPanel>

            <Button x:Name="DownloadTitleBarButton"
                    x:Uid="DownloadTitleBarButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Opacity="0"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0">
                <Grid Width="24"
                      Height="24">
                    <FontIcon FontSize="14"
                              Glyph="&#xE896;"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    <muxc:ProgressRing x:Name="DownloadTitleBarProgressRing"
                                       MinWidth="4"
                                       MinHeight="4"
                                       Width="24"
                                       Height="24"
                                       Minimum="0"
                                       Maximum="100"
                                       Value="0"
                                       IsActive="False"
                                       IsIndeterminate="False"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    <FontIcon x:Name="DownloadTitleBarCompleteBadge"
                              Glyph="&#xEC61;"
                              FontSize="10"
                              Visibility="Collapsed"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"/>
                </Grid>
                <Button.ContextFlyout>
                    <MenuFlyout x:Name="DownloadContextFlyout"
                                Opening="DownloadContextFlyout_Opening"
                                Closed="DownloadContextFlyout_Closed">
                        <MenuFlyoutItem x:Name="PinDownloadsToTitleBarMenuItem"
                                        x:Uid="PinDownloadsToTitleBarMenuItem"
                                        Click="PinDownloadsToTitleBarMenuItem_Click"/>
                        <MenuFlyoutItem x:Name="UnpinDownloadsFromTitleBarMenuItem"
                                        x:Uid="UnpinDownloadsFromTitleBarMenuItem"
                                        Click="UnpinDownloadsFromTitleBarMenuItem_Click"/>
                    </MenuFlyout>
                </Button.ContextFlyout>
                <Button.Flyout>
                    <Flyout x:Name="DownloadsFlyout"
                            Opened="DownloadsFlyout_Opened"
                            Closed="DownloadsFlyout_Closed">
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Padding"
                                        Value="0"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                                <Setter Property="CornerRadius"
                                        Value="8"/>
                            </Style>
                        </Flyout.FlyoutPresenterStyle>
                        <Border Width="360"
                                MaxHeight="420"
                                CornerRadius="8">
                            <Grid Padding="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid MinHeight="44"
                                      Padding="14,6,10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="DownloadsPanelTitle"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button x:Name="OpenDownloadsFolderButton"
                                                x:Uid="OpenDownloadsFolderButton"
                                                Width="32"
                                                Height="32"
                                                MinWidth="32"
                                                MinHeight="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="OpenDownloadsFolderButton_Click">
                                            <FontIcon Glyph="&#xE838;"
                                                      FontSize="14"/>
                                        </Button>
                                        <Button x:Name="PinDownloadsPanelButton"
                                                x:Uid="PinDownloadsPanelButton"
                                                Width="32"
                                                Height="32"
                                                MinWidth="32"
                                                MinHeight="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="PinDownloadsPanelButton_Click">
                                            <Grid Width="32"
                                                  Height="32">
                                                <FontIcon x:Name="PinDownloadsPanelGlyph"
                                                          Glyph="&#xE718;"
                                                          FontSize="14"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <FontIcon x:Name="PinDownloadsPanelPinnedGlyph"
                                                          Glyph="&#xE841;"
                                                          FontSize="14"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Visibility="Collapsed"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                    Opacity="0.6"/>

                            <Grid Grid.Row="2"
                                  MinHeight="160"
                                  Margin="0,0,4,4">
                                <ListView x:Name="DownloadsListView"
                                          IsItemClickEnabled="False"
                                          ContainerContentChanging="DownloadsListView_ContainerContentChanging">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch"/>
                                            <Setter Property="Padding"
                                                    Value="0"/>
                                            <Setter Property="CornerRadius"
                                                    Value="8"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:DownloadItemViewModel">
                                            <Grid MinHeight="76"
                                                  Padding="12,8,4,8"
                                                  Tag="{x:Bind Item, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0"
                                                      Width="28"
                                                      Height="28"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Top">
                                                    <Image Width="18"
                                                           Height="18"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Source="{x:Bind FileIconSource, Mode=OneWay}"
                                                           Visibility="{x:Bind FileIconVisibility, Mode=OneWay}"/>
                                                    <FontIcon Glyph="&#xE8A5;"
                                                              FontSize="18"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              Visibility="{x:Bind DefaultIconVisibility, Mode=OneWay}"/>
                                                </Grid>

                                                <Grid Grid.Column="1"
                                                      VerticalAlignment="Top">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="24"/>
                                                        <RowDefinition Height="22"/>
                                                        <RowDefinition Height="12"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{x:Bind FileName, Mode=OneWay}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                               Grid.Row="1"
                                                               FontSize="12"
                                                               Opacity="0.72"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{x:Bind StatusTextVisibility, Mode=OneWay}"/>
                                                    <HyperlinkButton x:Uid="OpenDownloadInlineButton"
                                                                     Grid.Row="1"
                                                                     FontSize="12"
                                                                     Padding="0"
                                                                     Margin="0"
                                                                     VerticalAlignment="Center"
                                                                     HorizontalAlignment="Left"
                                                                     Visibility="{x:Bind OpenVisibility, Mode=OneWay}"
                                                                     Tag="{x:Bind Item, Mode=OneWay}"
                                                                     Click="OpenDownloadItemButton_Click"/>
                                                    <Grid Grid.Row="2"
                                                          Height="12"
                                                          Visibility="{x:Bind ProgressVisibility, Mode=OneWay}">
                                                        <muxc:ProgressBar Maximum="100"
                                                                          Height="3"
                                                                          VerticalAlignment="Center"
                                                                          Loaded="DownloadProgressBar_Loaded"
                                                                          Unloaded="DownloadProgressBar_Unloaded"/>
                                                    </Grid>
                                                </Grid>

                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            Spacing="4"
                                                            VerticalAlignment="Center">
                                                    <Button x:Uid="ToggleDownloadItemButton"
                                                            Width="34"
                                                            Height="34"
                                                            MinWidth="34"
                                                            MinHeight="34"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Visibility="{x:Bind ToggleVisibility, Mode=OneWay}"
                                                            Tag="{x:Bind Item, Mode=OneWay}"
                                                            Click="ToggleDownloadItemButton_Click">
                                                        <FontIcon Glyph="{x:Bind ToggleGlyph, Mode=OneWay}"
                                                                  FontSize="14"/>
                                                    </Button>
                                                    <Button x:Uid="CancelDownloadItemButton"
                                                            Width="34"
                                                            Height="34"
                                                            MinWidth="34"
                                                            MinHeight="34"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Visibility="{x:Bind CancelVisibility, Mode=OneWay}"
                                                            Tag="{x:Bind Item, Mode=OneWay}"
                                                            Click="CancelDownloadItemButton_Click">
                                                        <FontIcon Glyph="&#xE711;"
                                                                  FontSize="10"/>
                                                    </Button>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Grid.ColumnSpan="2"
                                                            Orientation="Horizontal"
                                                            Spacing="4"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Visibility="{x:Bind HoverActionsVisibility, Mode=OneWay}">
                                                    <Button x:Uid="ShowDownloadInFolderButton"
                                                            Width="28"
                                                            Height="28"
                                                            MinWidth="28"
                                                            MinHeight="28"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Tag="{x:Bind Item, Mode=OneWay}"
                                                            Click="ShowDownloadInFolderButton_Click">
                                                        <FontIcon Glyph="&#xE838;"
                                                                  FontSize="13"/>
                                                    </Button>
                                                    <Button x:Uid="DeleteDownloadFileButton"
                                                            Width="28"
                                                            Height="28"
                                                            MinWidth="28"
                                                            MinHeight="28"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Tag="{x:Bind Item, Mode=OneWay}"
                                                            Click="DeleteDownloadFileButton_Click">
                                                        <FontIcon Glyph="&#xE74D;"
                                                                  FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock x:Name="DownloadsEmptyText"
                                           x:Uid="DownloadsEmptyText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.72"
                                           Visibility="Collapsed"/>
                            </Grid>

                            </Grid>
                        </Border>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button x:Name="MoreButton"
                    x:Uid="MoreButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0">
                <FontIcon FontSize="14"
                          Glyph="&#xE712;"/>
                <Button.Flyout>
                    <Flyout x:Name="MoreFlyout"
                            Opening="MoreFlyout_Opening"
                            Opened="MoreFlyout_Opened">
                        <StackPanel Width="320"
                                    Spacing="12">
                            <AutoSuggestBox x:Name="UrlAutoSuggestBox"
                                            x:Uid="UrlAutoSuggestBox"
                                            TabIndex="1"
                                            GotFocus="UrlAutoSuggestBox_GotFocus"
                                            Tapped="UrlAutoSuggestBox_Tapped"
                                            TextChanged="UrlAutoSuggestBox_TextChanged"
                                            SuggestionChosen="UrlAutoSuggestBox_SuggestionChosen"
                                            QuerySubmitted="UrlAutoSuggestBox_QuerySubmitted">
                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="40"
                                              MinWidth="280">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <AppBarButton x:Uid="DeleteUrlHistoryButton"
                                                          Grid.Column="1"
                                                          Width="32"
                                                          Height="32"
                                                          MinWidth="32"
                                                          MinHeight="32"
                                                          Padding="0"
                                                          Label=""
                                                          Background="Transparent"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                          Tag="{Binding}"
                                                          Click="DeleteUrlHistoryButton_Click">
                                                <AppBarButton.Template>
                                                    <ControlTemplate TargetType="AppBarButton">
                                                        <Grid Width="32"
                                                              Height="32"
                                                              Background="Transparent">
                                                            <VisualStateManager.VisualStateGroups>
                                                                <VisualStateGroup x:Name="CommonStates">
                                                                    <VisualState x:Name="Normal"/>
                                                                    <VisualState x:Name="PointerOver">
                                                                        <Storyboard>
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBackground"
                                                                                                           Storyboard.TargetProperty="Background">
                                                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                                                        Value="{ThemeResource SystemControlHighlightListLowBrush}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Pressed">
                                                                        <Storyboard>
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBackground"
                                                                                                           Storyboard.TargetProperty="Background">
                                                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                                                        Value="{ThemeResource SystemControlHighlightListMediumBrush}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Disabled"/>
                                                                </VisualStateGroup>
                                                            </VisualStateManager.VisualStateGroups>
                                                            <Border x:Name="ButtonBackground"
                                                                    CornerRadius="4"
                                                                    Background="Transparent"/>
                                                            <ContentPresenter Content="{TemplateBinding Icon}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </AppBarButton.Template>
                                                <AppBarButton.Icon>
                                                    <FontIcon FontSize="10"
                                                              Glyph="&#xE711;"/>
                                                </AppBarButton.Icon>
                                            </AppBarButton>
                                        </Grid>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>

                            <TextBlock x:Name="UrlErrorText"
                                       x:Uid="UrlErrorText"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8">
                                <Button x:Name="RestoreUrlButton"
                                        x:Uid="RestoreUrlButton"
                                        Style="{ThemeResource ButtonRevealStyle}"
                                        Click="RestoreUrlButton_Click"/>
                                <Button x:Name="CancelUrlButton"
                                        Style="{ThemeResource ButtonRevealStyle}"
                                        x:Uid="CancelUrlButton"
                                        Click="CancelUrlButton_Click"/>
                                <Button x:Name="SaveUrlButton"
                                        x:Uid="SaveUrlButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="SaveUrlButton_Click"/>
                            </StackPanel>

                            <StackPanel Margin="-15,0,-15,-15"
                                        Padding="2,2,2,2"
                                        Spacing="2">
                                <Border Height="1"
                                        Margin="-12,0"
                                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                        Opacity="0.6"/>

                                <Button x:Name="SitePermissionsEntryButton"
                                        x:Uid="SitePermissionsEntryButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="20"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="SitePermissionsEntryButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE72E;"
                                                  FontSize="16"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Uid="SitePermissionsEntryText"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <Border Height="1"
                                        Margin="-12,0"
                                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                        Opacity="0.6"/>

                                <Button x:Name="DownloadsEntryButton"
                                        x:Uid="DownloadsEntryButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="20"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="DownloadsEntryButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE896;"
                                                  FontSize="16"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Uid="DownloadsEntryText"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ElementName=DownloadsListView, Path=Items.Count}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.72"/>
                                    </Grid>
                                </Button>

                                <Grid x:Name="PinContainerRow"
                                      MinHeight="40">
                                    <Button x:Name="PinContainerButton"
                                            x:Uid="PinContainerButton"
                                            Canvas.ZIndex="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            MinHeight="20"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="PinContainerButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0"
                                                      Glyph="&#xE718;"
                                                      FontSize="16"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Uid="PinContainerText"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button x:Name="PinUnavailableInfoButton"
                                            x:Uid="PinUnavailableInfoButton"
                                            Style="{ThemeResource ButtonRevealStyle}"
                                            Canvas.ZIndex="1"
                                            Width="16"
                                            Height="16"
                                            MinWidth="16"
                                            MinHeight="16"
                                            Padding="0"
                                            Margin="0,0,8,0"
                                            CornerRadius="8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed"
                                            Click="PinUnavailableInfoButton_Click">
                                        <FontIcon Glyph="&#xE946;"
                                                  Margin="0,1,0,0"
                                                  FontSize="14"/>
                                    </Button>

                                    <muxc:TeachingTip x:Name="PinUnavailableTeachingTip"
                                                      x:Uid="PinUnavailableTeachingTip"
                                                      IsLightDismissEnabled="True"
                                                      TailVisibility="Visible"
                                                      PreferredPlacement="Bottom">
                                        <TextBlock x:Uid="PinUnavailableTeachingTipContent"
                                                   TextWrapping="Wrap"/>
                                        <muxc:TeachingTip.CloseButtonContent>
                                            <TextBlock x:Uid="PinUnavailableTeachingTipActionText"/>
                                        </muxc:TeachingTip.CloseButtonContent>
                                    </muxc:TeachingTip>
                                </Grid>

                                <Button x:Name="SettingsEntryButton"
                                        x:Uid="SettingsEntryButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="20"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="SettingsEntryButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE713;"
                                                  FontSize="16"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Uid="SettingsEntryText"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Frame x:Name="ContentFrame"
               Margin="0,32,0,0"/>

        <Grid x:Name="SettingsHost"
              Visibility="Collapsed"
              Background="Transparent"
              Margin="0,32,0,0"
              Canvas.ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Padding="20,16,20,12"
                        Spacing="8">
                <StackPanel x:Name="BreadcrumbPanel"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                <muxc:BreadcrumbBar x:Name="BreadcrumbNav"
                                    ItemsSource="{x:Bind BreadcrumbItems, Mode=OneWay}"
                                    ItemClicked="BreadcrumbNav_ItemClicked">
                    <muxc:BreadcrumbBar.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="28"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </DataTemplate>
                    </muxc:BreadcrumbBar.ItemTemplate>
                </muxc:BreadcrumbBar>
                </StackPanel>
            </StackPanel>

            <Frame x:Name="SettingsFrame"
                   Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>
