<ContentDialog
    x:Class="WinUIonWebUWP.Dialogs.RenameTileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Style="{StaticResource DefaultContentDialogStyle}"
    x:Uid="RenameTileDialog"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel Spacing="8">
        <TextBlock x:Uid="RenameTileDialogMessage"
                   TextWrapping="Wrap"
                   FontSize="14"/>
        <TextBox x:Name="NameTextBox"
                 x:Uid="RenameTileDialogNameTextBox"
                 TextChanged="NameTextBox_TextChanged"/>
        <TextBlock x:Name="NameErrorText"
                   x:Uid="RenameTileDialogNameErrorText"
                   Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
