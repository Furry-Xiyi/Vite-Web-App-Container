<ContentDialog
    x:Class="WinUIonWebUWP.Dialogs.PermissionRequestDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Style="{StaticResource DefaultContentDialogStyle}"
    x:Uid="PermissionRequestDialog"
    DefaultButton="Primary">

    <StackPanel Spacing="10">
        <TextBlock x:Name="PermissionMessageText"
                   TextWrapping="WrapWholeWords"
                   FontSize="14"/>
        <StackPanel Spacing="4">
            <TextBlock x:Name="PermissionOriginText"
                       TextWrapping="WrapWholeWords"
                       Opacity="0.78"/>
            <TextBlock x:Name="PermissionGestureText"
                       TextWrapping="WrapWholeWords"
                       Opacity="0.78"/>
        </StackPanel>
        <CheckBox x:Name="RememberDecisionCheckBox"
                  x:Uid="RememberPermissionDecisionCheckBox"/>
    </StackPanel>
</ContentDialog>
