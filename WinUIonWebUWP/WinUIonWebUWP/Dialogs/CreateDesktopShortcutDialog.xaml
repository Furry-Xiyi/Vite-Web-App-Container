<ContentDialog
    x:Class="WinUIonWebUWP.Dialogs.CreateDesktopShortcutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="CreateDesktopShortcutDialog"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel Spacing="12">
        <TextBlock x:Uid="CreateDesktopShortcutDialogMessage"
                   TextWrapping="Wrap"/>

        <ListView x:Name="ContainersListView"
                  MaxHeight="360"
                  SelectionMode="Single"
                  SelectionChanged="ContainersListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="64"
                          Padding="0,6"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <BitmapIcon Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    UriSource="{Binding IconUri}"
                                    ShowAsMonochrome="False"
                                    VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                            <TextBlock Text="{Binding HomeUrl}"
                                       FontSize="12"
                                       Opacity="0.72"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyText"
                   x:Uid="CreateDesktopShortcutDialogEmptyText"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
